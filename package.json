{
  "name": "use-filters-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Monorepo for @mbsatimov/use-filters — headless, URL-synced filter state for React.",
  "homepage": "https://use-filters.vercel.app",
  "bugs": "https://github.com/mbsatimov/use-filters/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbsatimov/use-filters.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspace @mbsatimov/use-filters",
    "dev": "npm run dev --workspace @mbsatimov/use-filters",
    "test": "npm run test --workspace @mbsatimov/use-filters",
    "test:watch": "npm run test:watch --workspace @mbsatimov/use-filters",
    "typecheck": "npm run typecheck --workspace @mbsatimov/use-filters",
    "check:exports": "npm run check:exports --workspace @mbsatimov/use-filters",
    "size": "npm run size --workspace @mbsatimov/use-filters",
    "docs": "npm run dev --workspace @use-filters/docs",
    "build:docs": "npm run build --workspace @mbsatimov/use-filters && npm run build --workspace @use-filters/docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@siberiacancode/eslint": "^2.18.0",
    "@siberiacancode/prettier": "^1.8.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3"
  }
}
