{
  "name": "@mbsatimov/use-filters",
  "version": "0.9.0",
  "description": "Headless, URL-synced filter state for React. Declare filters once, get typed params, resolved filter state, and nuqs-backed URL sync back — bring your own UI.",
  "author": {
    "name": "Mahkambek Satimov",
    "url": "https://github.com/mbsatimov"
  },
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "homepage": "https://use-filters.vercel.app",
  "bugs": "https://github.com/mbsatimov/use-filters/issues",
  "keywords": [
    "react",
    "hooks",
    "filters",
    "nuqs",
    "url-state",
    "query-params",
    "search-params",
    "querystring",
    "table-filters",
    "faceted-search",
    "pagination",
    "headless",
    "typescript"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbsatimov/use-filters.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "playground": "vite --config playground/vite.config.ts",
    "build:playground": "vite build --config playground/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "check:exports": "attw --pack .",
    "size": "size-limit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run check:exports && npm run size",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "size-limit": [
    {
      "name": "esm (whole package, min+gzip)",
      "path": "dist/index.js",
      "limit": "4 kB"
    }
  ],
  "peerDependencies": {
    "nuqs": ">=2",
    "react": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.0",
    "@siberiacancode/eslint": "^2.18.0",
    "@siberiacancode/prettier": "^1.8.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "lucide-react": "^0.544.0",
    "nuqs": "^2.6.0",
    "prettier": "^3.9.5",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.7",
    "size-limit": "^12.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.3.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
