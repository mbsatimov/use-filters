{
  "name": "@mbsatimov/use-filters",
  "version": "0.5.0",
  "description": "Headless, URL-synced filter state for React. Declare filters once, get typed params, resolved filter state, and nuqs-backed URL sync back — bring your own UI.",
  "author": {
    "name": "Mahkambek Satimov",
    "url": "https://github.com/mbsatimov"
  },
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bugs": "https://github.com/mbsatimov/use-filters/issues",
  "keywords": [
    "react",
    "filters",
    "filter",
    "react use filters",
    "use filters"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbsatimov/use-filters.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "playground": "vite --config playground/vite.config.ts",
    "build:playground": "vite build --config playground/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "nuqs": ">=2",
    "react": ">=18"
  },
  "devDependencies": {
    "@siberiacancode/eslint": "^2.18.0",
    "@siberiacancode/prettier": "^1.8.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "lucide-react": "^0.544.0",
    "nuqs": "^2.6.0",
    "prettier": "^3.9.5",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.3.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
