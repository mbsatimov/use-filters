{
  "name": "use-filters-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Monorepo for @mbsatimov/use-filters — headless, URL-synced filter state for React.",
  "homepage": "https://use-filters.vercel.app",
  "bugs": "https://github.com/mbsatimov/use-filters/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbsatimov/use-filters.git"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @mbsatimov/use-filters build",
    "dev": "pnpm --filter @mbsatimov/use-filters dev",
    "test": "pnpm --filter @mbsatimov/use-filters test",
    "test:watch": "pnpm --filter @mbsatimov/use-filters test:watch",
    "typecheck": "pnpm --filter @mbsatimov/use-filters typecheck",
    "typecheck:docs": "pnpm --filter @use-filters/docs typecheck",
    "check:exports": "pnpm --filter @mbsatimov/use-filters check:exports",
    "size": "pnpm --filter @mbsatimov/use-filters size",
    "docs": "pnpm --filter @use-filters/docs dev",
    "build:docs": "pnpm --filter @mbsatimov/use-filters build && pnpm --filter @use-filters/docs build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@siberiacancode/eslint": "^2.18.0",
    "@siberiacancode/prettier": "^1.8.0",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3"
  }
}
